# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Monime Payment (https://monime.io)
MONIME_API_KEY=your-monime-api-key
MONIME_WEBHOOK_SECRET=your-webhook-secret
MONIME_SPACE_ID=your-space-id
# Must match your Monime financial account currency (SLE for Sierra Leone)
MONIME_CURRENCY=SLE
# Optional SLE charge amounts (whole leones). Defaults: 120 / 480 / 1200
# MONIME_AMOUNT_MONTHLY=120
# MONIME_AMOUNT_SEMESTER=480
# MONIME_AMOUNT_ANNUAL=1200

# Attendance QR signing (min 32 chars)
QR_TOKEN_SECRET=change-this-to-a-long-random-secret-min-32-chars

# Subscription lifecycle cron (daily expiry checks & reminders)
CRON_SECRET=change-this-to-a-long-random-secret